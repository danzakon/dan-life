        "default_model": "hailuo-2.3",
        "description": "MiniMax Hailuo 2.3",
    },
}

CONFIG_DIR = Path.home() / ".config" / "mediagen"
CONFIG_FILE = CONFIG_DIR / ".env"


# =============================================================================
# Config
# =============================================================================

def load_config() -> dict:
    """Load config from ~/.config/mediagen/.env with environment overrides."""
    config = {}

    if CONFIG_FILE.exists():
        with open(CONFIG_FILE) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if "=" in line:
                    key, _, value = line.partition("=")
                    key, value = key.strip(), value.strip()
                    if value and value[0] in ("'", '"') and value[-1] == value[0]:
                        value = value[1:-1]
                    if key and value:
                        config[key] = value

    for var in [
        "OPENAI_API_KEY", "GEMINI_API_KEY", "KLING_API_KEY",
        "SEEDANCE_API_KEY", "RUNWAY_API_KEY", "MINIMAX_API_KEY",
        "DEFAULT_IMAGE_PROVIDER", "DEFAULT_IMAGE_MODEL",
        "DEFAULT_VIDEO_PROVIDER", "DEFAULT_VIDEO_MODEL",
    ]:
        if val := os.environ.get(var):
            config[var] = val

    return config


def detect_providers(config: dict) -> set:
    """Return the set of provider names that have API keys configured."""
    available = set()
    all_providers = {**IMAGE_PROVIDERS, **VIDEO_PROVIDERS}
    for name, info in all_providers.items():
        if config.get(info["key_var"]):
            available.add(name)
    return available


def resolve_provider_model(
    config: dict,
    available: set,
    explicit_provider: str | None,
    explicit_model: str | None,
    mode: str,  # "image" or "video"
) -> tuple[str, str]:
    """Resolve provider + model with config defaults and availability checks."""
    registry = IMAGE_PROVIDERS if mode == "image" else VIDEO_PROVIDERS
    default_provider_key = f"DEFAULT_{mode.upper()}_PROVIDER"
    default_model_key = f"DEFAULT_{mode.upper()}_MODEL"

    provider = explicit_provider or config.get(default_provider_key)
    if not provider:
        # Auto-select first available provider for this mode.
        for name in registry:
            if name in available:
                provider = name
                break

    if not provider:
        sys.stderr.write(f"Error: No {mode} provider available.\n")
        sys.stderr.write(f"Add an API key to {CONFIG_FILE}:\n")
        for name, info in registry.items():
            sys.stderr.write(f"  {info['key_var']}=your-api-key\n")
        sys.exit(1)

    if provider not in registry:
        sys.stderr.write(f"Error: Unknown {mode} provider '{provider}'.\n")
        sys.stderr.write(f"Available: {', '.join(registry.keys())}\n")
        sys.exit(1)

    if provider not in available:
        info = registry[provider]
        sys.stderr.write(f"Error: Provider '{provider}' has no API key configured.\n")
        sys.stderr.write(f"Add to {CONFIG_FILE}:\n  {info['key_var']}=your-api-key\n")
        sys.exit(1)

    model = explicit_model or config.get(default_model_key) or registry[provider]["default_model"]
    return provider, model


# =============================================================================
# Shared helpers
# =============================================================================

def size_to_aspect_ratio(size: str) -> str:
    """Convert a WxH size string to the nearest standard aspect ratio for Imagen."""
    try:
        w, h = map(int, size.lower().split("x"))
        ratio = w / h
        candidates = {"1:1": 1.0, "16:9": 16 / 9, "9:16": 9 / 16, "4:3": 4 / 3, "3:4": 3 / 4}
        return min(candidates, key=lambda r: abs(candidates[r] - ratio))
    except (ValueError, ZeroDivisionError):
        return "16:9"


def save_bytes(data: bytes, output: str):
    Path(output).parent.mkdir(parents=True, exist_ok=True)
    Path(output).write_bytes(data)


def download_file(url: str, output: str, timeout: int = 120):
    Path(output).parent.mkdir(parents=True, exist_ok=True)
    req = urllib.request.Request(url, headers={"User-Agent": "mediagen/1.0"})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        Path(output).write_bytes(resp.read())


def die(msg: str):
    sys.stderr.write(f"Error: {msg}\n")
    sys.exit(1)


# =============================================================================
# Image generation — OpenAI
# =============================================================================

def gen_image_openai(prompt: str, output: str, model: str, size: str, quality: str, config: dict) -> dict:
    from openai import OpenAI

    client = OpenAI(api_key=config["OPENAI_API_KEY"])
    kwargs: dict = {"model": model, "prompt": prompt, "n": 1, "size": size}

    if model == "dall-e-3":
        kwargs["quality"] = "hd" if quality in ("high", "hd") else "standard"
        kwargs["response_format"] = "b64_json"
    else:
        kwargs["quality"] = quality if quality in ("low", "medium", "high") else "high"
        kwargs["response_format"] = "b64_json"

    response = client.images.generate(**kwargs)
    save_bytes(base64.b64decode(response.data[0].b64_json), output)

    return {"path": str(Path(output).resolve()), "provider": "openai", "model": model, "size": size}


def edit_image_openai(image_path: str, prompt: str, output: str, model: str, size: str, config: dict) -> dict:
    from openai import OpenAI

    # gpt-image-1-mini does not support edits; fall back to the full model.
    if model in ("gpt-image-1-mini", "dall-e-3"):
        model = "gpt-image-1"

    client = OpenAI(api_key=config["OPENAI_API_KEY"])
    with open(image_path, "rb") as img:
        response = client.images.edit(model=model, image=img, prompt=prompt, n=1, size=size)

    save_bytes(base64.b64decode(response.data[0].b64_json), output)
    return {"path": str(Path(output).resolve()), "provider": "openai", "model": model, "size": size}


# =============================================================================
# Image generation — Google
# =============================================================================

def gen_image_google(prompt: str, output: str, model: str, size: str, quality: str, config: dict) -> dict:
    from google import genai
    from google.genai import types

    client = genai.Client(api_key=config["GEMINI_API_KEY"])
    aspect_ratio = size_to_aspect_ratio(size)

    if model == "gemini-2.0-flash-exp":
        response = client.models.generate_content(
            model=model,
            contents=prompt,
            config=types.GenerateContentConfig(response_modalities=["IMAGE", "TEXT"]),
        )
        image_bytes = None
        for part in response.candidates[0].content.parts:
            if hasattr(part, "inline_data") and part.inline_data:
                image_bytes = part.inline_data.data
                break
        if not image_bytes:
            die("Gemini returned no image data.")
    else:
        response = client.models.generate_images(
            model=model,
            prompt=prompt,
            config=types.GenerateImagesConfig(
                number_of_images=1,
                aspect_ratio=aspect_ratio,
                safety_filter_level="BLOCK_SOME",
                person_generation="dont_allow",
            ),
        )
        if not response.generated_images:
            die("Imagen returned no images.")
        image_bytes = response.generated_images[0].image.image_bytes

    save_bytes(image_bytes, output)
    return {
        "path": str(Path(output).resolve()),
        "provider": "google",
        "model": model,
        "size": size,
        "aspect_ratio": aspect_ratio,
    }


def edit_image_google(image_path: str, prompt: str, output: str, config: dict) -> dict:
    """Edit an image using Gemini 2.0 Flash multimodal input → image output."""
    from google import genai
    from google.genai import types

    client = genai.Client(api_key=config["GEMINI_API_KEY"])
    model = "gemini-2.0-flash-exp"
    img_bytes = Path(image_path).read_bytes()
    mime_type = "image/png" if image_path.lower().endswith(".png") else "image/jpeg"

    response = client.models.generate_content(
        model=model,
        contents=[
            types.Part.from_bytes(data=img_bytes, mime_type=mime_type),
            prompt,
        ],
        config=types.GenerateContentConfig(response_modalities=["IMAGE", "TEXT"]),
    )

    image_bytes = None
    for part in response.candidates[0].content.parts:
        if hasattr(part, "inline_data") and part.inline_data:
            image_bytes = part.inline_data.data
            break

    if not image_bytes:
        die("Gemini returned no image data.")

    save_bytes(image_bytes, output)
    return {"path": str(Path(output).resolve()), "provider": "google", "model": model}


# =============================================================================
# Video — submit functions (all async; return task_id immediately)
# =============================================================================

def submit_video_openai(prompt: str, model: str, duration: int, aspect_ratio: str, config: dict) -> dict:
    import requests

    headers = {"Authorization": f"Bearer {config['OPENAI_API_KEY']}", "Content-Type": "application/json"}
    resp = requests.post(
        "https://api.openai.com/v1/video/generations",
        headers=headers,
        json={"model": model, "prompt": prompt, "duration": duration, "n": 1, "resolution": "720p"},
        timeout=30,
    )
    if not resp.ok:
        die(f"OpenAI API error {resp.status_code}: {resp.text[:500]}")
    data = resp.json()
    return {"task_id": data.get("id", data.get("task_id", "")), "provider": "openai", "model": model, "status": "submitted"}


def submit_video_google(prompt: str, model: str, duration: int, aspect_ratio: str, config: dict) -> dict:
    from google import genai
    from google.genai import types

    client = genai.Client(api_key=config["GEMINI_API_KEY"])
    operation = client.models.generate_video(
        model=model,
        prompt=prompt,
        config=types.GenerateVideoConfig(
            aspect_ratio=aspect_ratio,
            duration_seconds=duration,
            person_generation="dont_allow",
        ),
    )
    return {"task_id": operation.name, "provider": "google", "model": model, "status": "submitted"}


def submit_video_kling(prompt: str, model: str, duration: int, aspect_ratio: str, config: dict) -> dict:
    import requests

    model_map = {"kling-3.0": "kling-video-v3.0-pro-text", "kling-2.6": "kling-video-v2.6-pro-text"}
    headers = {"X-API-Key": config["KLING_API_KEY"], "Content-Type": "application/json"}
    resp = requests.post(
        "https://api.piapi.ai/api/kling/v1/video",
        headers=headers,
        json={
            "model": model_map.get(model, "kling-video-v3.0-pro-text"),
            "prompt": prompt,
            "duration": str(duration),
            "aspect_ratio": aspect_ratio,
        },
        timeout=30,
    )
    if not resp.ok:
        die(f"Kling API error {resp.status_code}: {resp.text[:500]}")
    data = resp.json()
    return {"task_id": data.get("task_id", data.get("id", "")), "provider": "kling", "model": model, "status": "submitted"}


