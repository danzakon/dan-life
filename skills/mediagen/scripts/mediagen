        timeout=30,
    )
    if not resp.ok:
        die(f"SeedDance API error {resp.status_code}: {resp.text[:500]}")
    data = resp.json()
    return {"task_id": data.get("task_id", data.get("id", "")), "provider": "seedance", "model": model, "status": "submitted"}


def submit_video_runway(prompt: str, model: str, duration: int, aspect_ratio: str, config: dict) -> dict:
    import requests

    model_map = {"gen-4.5": "gen4_turbo", "gen-4": "gen4", "gen-3-alpha": "gen3a_turbo"}
    headers = {
        "Authorization": f"Bearer {config['RUNWAY_API_KEY']}",
        "Content-Type": "application/json",
        "X-Runway-Version": "2024-11-06",
    }
    resp = requests.post(
        "https://api.runwayml.com/v1/text_to_video",
        headers=headers,
        json={"model": model_map.get(model, "gen4_turbo"), "promptText": prompt, "duration": duration, "ratio": aspect_ratio},
        timeout=30,
    )
    if not resp.ok:
        die(f"Runway API error {resp.status_code}: {resp.text[:500]}")
    data = resp.json()
    return {"task_id": data.get("id", ""), "provider": "runway", "model": model, "status": "submitted"}


def submit_video_minimax(prompt: str, model: str, duration: int, aspect_ratio: str, config: dict) -> dict:
    import requests

    model_map = {"hailuo-2.3": "MiniMax-Hailuo-2.3", "hailuo-02": "MiniMax-Hailuo-02"}
    headers = {"Authorization": f"Bearer {config['MINIMAX_API_KEY']}", "Content-Type": "application/json"}
    resp = requests.post(
        "https://platform.minimax.io/v1/video_generation",
        headers=headers,
        json={"model": model_map.get(model, "MiniMax-Hailuo-2.3"), "prompt": prompt, "duration": duration},
        timeout=30,
    )
    if not resp.ok:
        die(f"MiniMax API error {resp.status_code}: {resp.text[:500]}")
    data = resp.json()
    return {"task_id": data.get("task_id", data.get("id", "")), "provider": "minimax", "model": model, "status": "submitted"}


# =============================================================================
# Video — poll functions (block until done, then download)
# =============================================================================

def poll_video_openai(task_id: str, output: str, config: dict, timeout: int = 600) -> dict:
    import requests

    headers = {"Authorization": f"Bearer {config['OPENAI_API_KEY']}"}
    deadline = time.time() + timeout

    while time.time() < deadline:
        resp = requests.get(
            f"https://api.openai.com/v1/video/generations/{task_id}",
            headers=headers, timeout=30,
        )
        if not resp.ok:
            die(f"OpenAI poll error {resp.status_code}: {resp.text[:500]}")
        data = resp.json()
        status = data.get("status", "")

        if status == "completed":
            url = (data.get("data") or [{}])[0].get("url")
            if not url:
                die("No video URL in completed OpenAI response.")
            download_file(url, output)
            return {"path": str(Path(output).resolve()), "provider": "openai", "task_id": task_id, "size_bytes": Path(output).stat().st_size}
        elif status in ("failed", "cancelled"):
            die(f"Video generation {status}: {data.get('error', '')}")

        sys.stderr.write(f"  Status: {status}...\n")
        time.sleep(5)

    die(f"Timed out after {timeout}s")


def poll_video_google(task_id: str, output: str, config: dict, timeout: int = 600) -> dict:
    from google import genai

    client = genai.Client(api_key=config["GEMINI_API_KEY"])
    deadline = time.time() + timeout

    while time.time() < deadline:
        op = client.operations.get(name=task_id)

        if getattr(op, "done", False):
            if getattr(op, "error", None):
                die(f"Veo generation failed: {op.error.message}")

            result = getattr(op, "result", None)
            videos = getattr(result, "generated_videos", []) if result else []
            if not videos:
                die("Veo returned no generated videos.")

            video = videos[0].video
            # Prefer URI download; fall back to SDK download method.
            if hasattr(video, "uri") and video.uri:
                download_file(video.uri, output)
            else:
                video_bytes = client.files.download(file=video)
                save_bytes(video_bytes, output)

            return {
                "path": str(Path(output).resolve()),
                "provider": "google",
                "task_id": task_id,
                "size_bytes": Path(output).stat().st_size,
            }

        sys.stderr.write("  Waiting for Veo...\n")
        time.sleep(10)

    die(f"Timed out after {timeout}s")


def poll_video_kling(task_id: str, output: str, config: dict, timeout: int = 600) -> dict:
    import requests

    headers = {"X-API-Key": config["KLING_API_KEY"]}
    deadline = time.time() + timeout

    while time.time() < deadline:
        resp = requests.get(
            f"https://api.piapi.ai/api/kling/v1/video/{task_id}",
            headers=headers, timeout=30,
        )
        if not resp.ok:
            die(f"Kling poll error {resp.status_code}: {resp.text[:500]}")
        data = resp.json()
        status = data.get("status", "")

        if status == "completed":
            videos = data.get("output", {}).get("videos", [])
            if not videos:
                die("No video URL in Kling response.")
            download_file(videos[0]["url"], output)
            return {"path": str(Path(output).resolve()), "provider": "kling", "task_id": task_id, "size_bytes": Path(output).stat().st_size}
        elif status in ("failed", "error"):
            die(f"Kling video generation failed: {data.get('error', '')}")

        sys.stderr.write(f"  Status: {status}...\n")
        time.sleep(5)

    die(f"Timed out after {timeout}s")


def poll_video_seedance(task_id: str, output: str, config: dict, timeout: int = 600) -> dict:
    import requests

    headers = {"Authorization": f"Bearer {config['SEEDANCE_API_KEY']}"}
    deadline = time.time() + timeout

    while time.time() < deadline:
        resp = requests.get(
            f"https://api.seedance.best/v2/tasks/{task_id}",
            headers=headers, timeout=30,
        )
        if not resp.ok:
            die(f"SeedDance poll error {resp.status_code}: {resp.text[:500]}")
        data = resp.json()
        status = data.get("status", "").lower()

        if status in ("completed", "success"):
            url = data.get("video_url") or data.get("url")
            if not url:
                die("No video URL in SeedDance response.")
            download_file(url, output)
            return {"path": str(Path(output).resolve()), "provider": "seedance", "task_id": task_id, "size_bytes": Path(output).stat().st_size}
        elif status in ("failed", "error"):
            die(f"SeedDance video generation failed: {data.get('error', '')}")

        sys.stderr.write(f"  Status: {status}...\n")
        time.sleep(5)

    die(f"Timed out after {timeout}s")


def poll_video_runway(task_id: str, output: str, config: dict, timeout: int = 600) -> dict:
    import requests

    headers = {"Authorization": f"Bearer {config['RUNWAY_API_KEY']}", "X-Runway-Version": "2024-11-06"}
    deadline = time.time() + timeout

    while time.time() < deadline:
        resp = requests.get(
            f"https://api.runwayml.com/v1/tasks/{task_id}",
            headers=headers, timeout=30,
        )
        if not resp.ok:
            die(f"Runway poll error {resp.status_code}: {resp.text[:500]}")
        data = resp.json()
        status = data.get("status", "")

        if status == "SUCCEEDED":
            outputs = data.get("output", [])
            if not outputs:
                die("No video URL in Runway response.")
            download_file(outputs[0], output)
            return {"path": str(Path(output).resolve()), "provider": "runway", "task_id": task_id, "size_bytes": Path(output).stat().st_size}
        elif status in ("FAILED", "CANCELLED"):
            die(f"Runway video {status.lower()}: {data.get('failure', '')}")

        sys.stderr.write(f"  Status: {status}...\n")
        time.sleep(5)

    die(f"Timed out after {timeout}s")


def poll_video_minimax(task_id: str, output: str, config: dict, timeout: int = 600) -> dict:
    import requests

    headers = {"Authorization": f"Bearer {config['MINIMAX_API_KEY']}"}
    deadline = time.time() + timeout

    while time.time() < deadline:
        resp = requests.get(
            "https://platform.minimax.io/v1/query/video_generation",
            headers=headers, params={"task_id": task_id}, timeout=30,
        )
        if not resp.ok:
            die(f"MiniMax poll error {resp.status_code}: {resp.text[:500]}")
        data = resp.json()
        status = data.get("status", "")

        if status in ("Success", "Completed"):
            url = data.get("download_url") or data.get("file_url")
            if not url:
                die("No download URL in MiniMax response.")
            download_file(url, output)
            return {"path": str(Path(output).resolve()), "provider": "minimax", "task_id": task_id, "size_bytes": Path(output).stat().st_size}
        elif status in ("Fail", "Failed"):
            die(f"MiniMax video generation failed: {data.get('error', '')}")

        sys.stderr.write(f"  Status: {status}...\n")
        time.sleep(5)

    die(f"Timed out after {timeout}s")


_VIDEO_SUBMIT = {
    "openai": submit_video_openai,
    "google": submit_video_google,
    "kling": submit_video_kling,
    "seedance": submit_video_seedance,
    "runway": submit_video_runway,
    "minimax": submit_video_minimax,
}

_VIDEO_POLL = {
    "openai": poll_video_openai,
    "google": poll_video_google,
    "kling": poll_video_kling,
    "seedance": poll_video_seedance,
    "runway": poll_video_runway,
    "minimax": poll_video_minimax,
}


# =============================================================================
# Commands
# =============================================================================

def cmd_image_gen(args, config, available):
    parts = args.command
    if len(parts) < 2:
        die('Usage: mediagen i:gen "prompt" -o output.png')
    prompt = " ".join(parts[1:])
    output = args.output or "output.png"
    size = args.size or "1792x1024"

    provider, model = resolve_provider_model(config, available, args.provider, args.model, "image")
    sys.stderr.write(f"Generating image [{provider}/{model}]...\n")

    if provider == "openai":
        result = gen_image_openai(prompt, output, model, size, args.quality, config)
    elif provider == "google":
        result = gen_image_google(prompt, output, model, size, args.quality, config)
    else:
        die(f"Image generation not supported for provider '{provider}'.")

    if args.json:
        print(json.dumps(result))
    else:
        size_bytes = Path(output).stat().st_size
        print(f"Saved: {result['path']}  [provider: {provider}, model: {model}, {size_bytes:,} bytes]")


def cmd_image_edit(args, config, available):
    parts = args.command
    if len(parts) < 3:
        die('Usage: mediagen i:edit image.png "edit instruction" -o output.png')
    image_path, prompt = parts[1], " ".join(parts[2:])
    output = args.output or "edited.png"

    if not Path(image_path).exists():
        die(f"Image file not found: {image_path}")

    provider, model = resolve_provider_model(config, available, args.provider, args.model, "image")
    sys.stderr.write(f"Editing image [{provider}/{model}]...\n")

    if provider == "openai":
        result = edit_image_openai(image_path, prompt, output, model, args.size or "1024x1024", config)
    elif provider == "google":
        result = edit_image_google(image_path, prompt, output, config)
    else:
        die(f"Image editing not supported for provider '{provider}'.")

    if args.json:
        print(json.dumps(result))
    else:
        size_bytes = Path(output).stat().st_size
        print(f"Saved: {result['path']}  [provider: {provider}, model: {result['model']}, {size_bytes:,} bytes]")


def cmd_video_gen(args, config, available):
    parts = args.command
    if len(parts) < 2:
        die('Usage: mediagen v:gen "prompt" -o clip.mp4')
    prompt = " ".join(parts[1:])
    output = args.output or "output.mp4"

    provider, model = resolve_provider_model(config, available, args.provider, args.model, "video")
    sys.stderr.write(f"Submitting video job [{provider}/{model}]...\n")

    task_info = _VIDEO_SUBMIT[provider](prompt, model, args.duration, args.aspect_ratio, config)

    if args.no_wait:
        if args.json:
            print(json.dumps(task_info))
        else:
            print(f"Task submitted: {task_info['task_id']}  [provider: {provider}]")
            print(f"Download when ready:")
            print(f"  mediagen v:status {task_info['task_id']} -o {output} --provider {provider}")
        return

    sys.stderr.write(f"Waiting for video... (task: {task_info['task_id']})\n")
    result = _VIDEO_POLL[provider](task_info["task_id"], output, config)
    result["model"] = model

    if args.json:
        print(json.dumps(result))
    else:
        size_mb = result.get("size_bytes", 0) / 1_000_000
        print(f"Saved: {result['path']}  [provider: {provider}, model: {model}, {size_mb:.1f} MB]")


def cmd_video_status(args, config, available):
    parts = args.command
    if len(parts) < 2:
        die("Usage: mediagen v:status TASK_ID -o clip.mp4 --provider PROVIDER")
    task_id = parts[1]
    output = args.output or "output.mp4"

    provider, model = resolve_provider_model(config, available, args.provider, args.model, "video")
    sys.stderr.write(f"Checking status [{provider}] task: {task_id}...\n")

    result = _VIDEO_POLL[provider](task_id, output, config)
    result["model"] = model

    if args.json:
        print(json.dumps(result))
    else:
        size_mb = result.get("size_bytes", 0) / 1_000_000
        print(f"Saved: {result['path']}  [provider: {provider}, {size_mb:.1f} MB]")


def cmd_providers(config, available):
    from rich.console import Console
    from rich.table import Table

    console = Console()
    table = Table(title="mediagen providers", show_lines=True)
    table.add_column("Provider", style="bold")
    table.add_column("Status")
    table.add_column("Key var")
    table.add_column("Image models")
    table.add_column("Video models")

    all_names = sorted(set(list(IMAGE_PROVIDERS.keys()) + list(VIDEO_PROVIDERS.keys())))
    for name in all_names:
        img_info = IMAGE_PROVIDERS.get(name)
        vid_info = VIDEO_PROVIDERS.get(name)
        key_var = (img_info or vid_info or {}).get("key_var", "")
        is_avail = name in available
        status = "[green]configured[/green]" if is_avail else "[dim]no key[/dim]"
        img_models = "\n".join(img_info["models"]) if img_info else "[dim]—[/dim]"
        vid_models = "\n".join(vid_info["models"]) if vid_info else "[dim]—[/dim]"
        table.add_row(name, status, key_var, img_models, vid_models)

    console.print(table)
    console.print(f"\nConfig: [dim]{CONFIG_FILE}[/dim]")


def cmd_models(config, available):
    from rich.console import Console
    from rich.table import Table

    console = Console()

    def make_table(title, registry):
        t = Table(title=title, show_lines=True)
        t.add_column("Provider")
        t.add_column("Model")
        t.add_column("Default")
        t.add_column("Status")
        for name, info in registry.items():
            is_avail = name in available
            status = "[green]ready[/green]" if is_avail else "[dim]no key[/dim]"
            default = info["default_model"]
            for i, model in enumerate(info["models"]):
                t.add_row(
                    name if i == 0 else "",
                    model,
                    "[cyan]default[/cyan]" if model == default else "",
                    status if i == 0 else "",
                )
        return t

    console.print(make_table("Image models", IMAGE_PROVIDERS))
    console.print()
    console.print(make_table("Video models", VIDEO_PROVIDERS))


# =============================================================================
# Main
# =============================================================================

def main():
    parser = argparse.ArgumentParser(
        description="Generate AI images and videos from the command line",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  mediagen i:gen "prompt" -o output.png            Generate an image
  mediagen i:edit image.png "edit" -o out.png      Edit an existing image
  mediagen v:gen "prompt" -o clip.mp4              Generate a video (blocks until done)
  mediagen v:gen "prompt" -o clip.mp4 --no-wait    Submit job, print task ID and exit
  mediagen v:status TASK_ID -o clip.mp4            Download a previously submitted video
  mediagen providers                               Show all providers and their status
  mediagen models                                  List all models per provider

Flags:
  --provider    openai | google | kling | seedance | runway | minimax
  --model       Model name (overrides DEFAULT_*_MODEL from config)
  --size        Image size (default: 1792x1024)
  --quality     Image quality: low, medium, high (default: high)
  --duration    Video duration in seconds (default: 8)
  --aspect-ratio  Video aspect ratio (default: 16:9)
  --no-wait     Submit video without polling
  --json        Raw JSON output to stdout

Config: ~/.config/mediagen/.env
  OPENAI_API_KEY, GEMINI_API_KEY, KLING_API_KEY, SEEDANCE_API_KEY,
  RUNWAY_API_KEY, MINIMAX_API_KEY
  DEFAULT_IMAGE_PROVIDER=openai    DEFAULT_IMAGE_MODEL=gpt-image-1.5
  DEFAULT_VIDEO_PROVIDER=google    DEFAULT_VIDEO_MODEL=veo-3.1-generate-001
""",
    )
    parser.add_argument("command", nargs="*", help="Command and arguments")
    parser.add_argument("--provider", help="Provider override")
    parser.add_argument("--model", help="Model override")
    parser.add_argument("--size", help="Image size, e.g. 1792x1024")
    parser.add_argument("--quality", default="high", help="Image quality: low, medium, high")
    parser.add_argument("--duration", type=int, default=8, help="Video duration in seconds")
    parser.add_argument("--aspect-ratio", default="16:9", dest="aspect_ratio", help="Video aspect ratio")
    parser.add_argument("--no-wait", action="store_true", help="Submit video job and exit without polling")
    parser.add_argument("--json", action="store_true", help="Output raw JSON")
    parser.add_argument("--output", "-o", help="Output file path")
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    config = load_config()
    available = detect_providers(config)
    command = args.command[0].lower()

    if command == "i:gen":
        cmd_image_gen(args, config, available)
    elif command == "i:edit":
        cmd_image_edit(args, config, available)
    elif command == "v:gen":
        cmd_video_gen(args, config, available)
    elif command == "v:status":
        cmd_video_status(args, config, available)
    elif command == "providers":
        cmd_providers(config, available)
    elif command == "models":
        cmd_models(config, available)
    else:
        sys.stderr.write(f"Unknown command: {command}\n")
        sys.stderr.write("Available: i:gen, i:edit, v:gen, v:status, providers, models\n")
        sys.exit(1)


if __name__ == "__main__":
    main()
