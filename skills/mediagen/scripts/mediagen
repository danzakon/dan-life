#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "openai>=1.0",
#   "google-genai>=1.0",
#   "requests>=2.28",
#   "rich>=13.0",
# ]
# ///
"""mediagen - Generate AI images and videos from the command line.

A self-contained CLI tool supporting multiple AI providers with graceful
degradation when API keys are absent. Designed as the media-generation
equivalent of xquery/ytquery.

Config: ~/.config/mediagen/.env
    OPENAI_API_KEY=...           # GPT-Image + Sora 2
    GEMINI_API_KEY=...           # Imagen 4 + Veo 3.1
    KLING_API_KEY=...            # Kling 3.0 via piapi.ai
    SEEDANCE_API_KEY=...         # SeedDance 2.0
    RUNWAY_API_KEY=...           # Runway Gen-4.5
    MINIMAX_API_KEY=...          # MiniMax Hailuo 2.3
    DEFAULT_IMAGE_PROVIDER=openai
    DEFAULT_IMAGE_MODEL=gpt-image-1.5
    DEFAULT_VIDEO_PROVIDER=google
    DEFAULT_VIDEO_MODEL=veo-3.1-generate-001
"""

import argparse
import base64
import json
import os
import sys
import time
import urllib.request
import urllib.error
from pathlib import Path


# =============================================================================
# Provider / model registry
# =============================================================================

IMAGE_PROVIDERS = {
    "openai": {
        "key_var": "OPENAI_API_KEY",
        "models": ["gpt-image-1.5", "gpt-image-1", "gpt-image-1-mini", "dall-e-3"],
        "default_model": "gpt-image-1.5",
        "description": "GPT-Image (highest quality)",
    },
    "google": {
        "key_var": "GEMINI_API_KEY",
        "models": [
            "imagen-4.0-generate-001",
            "imagen-4.0-ultra-generate-001",
            "imagen-4.0-fast-generate-001",
            "gemini-2.0-flash-exp",
        ],
        "default_model": "imagen-4.0-generate-001",
        "description": "Imagen 4 / Gemini 2.0 Flash",
    },
}

VIDEO_PROVIDERS = {
    "openai": {
        "key_var": "OPENAI_API_KEY",
        "models": ["sora-2", "sora-2-pro"],
        "default_model": "sora-2",
        "description": "Sora 2 (best quality)",
    },
    "google": {
        "key_var": "GEMINI_API_KEY",
        "models": ["veo-3.1-generate-001", "veo-3.1-generate-preview"],
        "default_model": "veo-3.1-generate-001",
        "description": "Veo 3.1 (native audio)",
    },
    "kling": {
        "key_var": "KLING_API_KEY",
        "models": ["kling-3.0", "kling-2.6"],
        "default_model": "kling-3.0",
        "description": "Kling 3.0 via piapi.ai (cinematic motion)",
    },
    "seedance": {
        "key_var": "SEEDANCE_API_KEY",
        "models": ["seedance-2.0"],
        "default_model": "seedance-2.0",
